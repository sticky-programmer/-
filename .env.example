PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Local test defaults are created automatically when data/users.json does not exist.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456

# Set this on the server if you want to override returned absolute image URLs.
# If empty: local uses request host, production defaults to http://8.137.192.209
BASE_URL=

# Change this in production.
SESSION_SECRET=change-this-session-secret

# Set true only when the service is behind HTTPS.
COOKIE_SECURE=false
