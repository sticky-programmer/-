PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Local test defaults are created automatically when data/users.json does not exist.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456

# Optional initial header API key. It is used only when data/settings.json does not exist.
# External frontends can call protected image APIs with request header: KEY: your-api-key
API_KEY=

# Set this on the server if you want to override returned absolute image URLs.
# If empty: local uses request host, production defaults to http://8.137.192.209
BASE_URL=

# Change this in production.
SESSION_SECRET=change-this-session-secret

# Set true only when the service is behind HTTPS.
COOKIE_SECURE=false

# Cookie SameSite policy: lax, strict, or none.
# For real cross-site cookie requests, use COOKIE_SAME_SITE=none and HTTPS with COOKIE_SECURE=true.
COOKIE_SAME_SITE=lax

# Initial comma-separated allowed frontend origins. Used only when data/settings.json does not exist.
# You can change CORS dynamically in the admin UI without restarting the server.
# Use * only if you intentionally allow any origin.
# Requests with the KEY header still need the frontend origin to be allowed by CORS.
CORS_ORIGINS=http://8.137.192.209,http://localhost:5173,http://127.0.0.1:5173
